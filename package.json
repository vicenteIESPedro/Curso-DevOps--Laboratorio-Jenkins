{
  "name": "cep-cicd-jenkins-backend",
  "version": "1.0.0",
  "description": "Backend para app de recetas (CI/CD Jenkins)",
  "keywords": [],
  "license": "MIT",
  "author": "Lemoncode",
  "type": "module",
  "main": "./dist/server.mjs",
  "scripts": {
    "build": "tsdown src/server.ts",
    "db:migrate": "prisma db push",
    "db:seed": "prisma db seed",
    "dev": "nodemon",
    "format:check": "oxfmt --check",
    "format:write": "oxfmt --write",
    "lint": "oxlint",
    "pretest:e2e": "npm run db:migrate",
    "prisma:generate": "prisma generate",
    "start": "node ./dist/server.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "6.19",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "nodemon": "^3.1.14",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "prisma": "6.19",
    "supertest": "^7.2.2",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "vitest-mock-extended": "^4.0.0"
  }
}
